    "plan.explanation.anchorSummary": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die wichtigsten Lifts (%@) setzen die Basis für deine Progression. Die übrigen Übungen ergänzen Volumen und Balance."
          }
        }
      }
    },
    "plan.explanation.focusMuscles": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zusätzliches Volumen geht an %@ als Priorität."
          }
        }
      }
    },
    "plan.explanation.injuries": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Übungsauswahl vermeidet Bewegungen, die deine Einschränkungen reizen könnten."
          }
        }
      }
    },
    "plan.explanation.intro": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser %@-Plan ist auf dein Trainingsziel %@ und dein aktuelles Niveau %@ abgestimmt."
          }
        }
      }
    },
    "plan.explanation.muscleBalanceDrift": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ hinkt zuletzt etwas hinterher; dieser Plan ergänzt dort zusätzliche Arbeit."
          }
        }
      }
    },
    "plan.explanation.neglectMuscles": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Volumen für %@ bleibt auf deinen Wunsch minimal."
          }
        }
      }
    },
    "plan.explanation.phase.buildLowCapacity": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Volumen ist konservativ gesetzt und passt zu deiner Regenerationskapazität."
          }
        }
      }
    },
    "plan.explanation.phase.buildLowRecovery": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Volumen ist in diesem Zyklus wegen niedrigerer Regeneration etwas reduziert: Qualität vor Quantität."
          }
        }
      }
    },
    "plan.explanation.phase.deload": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deload-Woche: Volumen und Intensität sind reduziert, damit du frisch bleibst."
          }
        }
      }
    },
    "plan.explanation.phase.fatigueManagement": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fatigue-Management: Das Volumen wird etwas zurückgenommen, um Fortschritt zu sichern."
          }
        }
      }
    },
    "plan.explanation.phase.pushConservative": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Push-Phase, aber das Volumen bleibt passend zu deiner aktuellen Regeneration."
          }
        }
      }
    },
    "plan.explanation.phase.pushRecovered": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Push-Phase mit genug Regeneration: Kleine PRs sind realistisch, wenn du konstant bleibst."
