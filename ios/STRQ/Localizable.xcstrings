      }
    },
    "progression.coachNote.plateaued.bodyweight": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast diese Variation ausgereizt. Wechsle zu einer schwereren Version oder nutze Tempo-/Pausenarbeit für mehr Schwierigkeit."
          }
        }
      }
    },
    "progression.coachNote.plateaued.default": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Leistung ist im Plateau. Versuche 1-2 zusätzliche Wiederholungen vor der Gewichtserhöhung oder wechsle zu einer ähnlichen Übung für neuen Reiz."
          }
        }
      }
    },
    "progression.coachNote.plateaued.heavyCompound": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Lift stockt. Halte das aktuelle Gewicht noch eine Einheit und versuche dann eine kleine Steigerung. Wenn es anhält, prüfe einen Variationstausch."
          }
        }
      }
    },
    "progression.coachNote.progressing.default": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf Kurs. Trainiere mit Fokus weiter, dann folgt die Progression."
          }
        }
      }
    },
    "progression.coachNote.progressing.doubleProgression": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du arbeitest auf das obere Ende des Wiederholungsbereichs hin. Wenn du es konstant erreichst, erhöhe das Gewicht."
          }
        }
      }
    },
    "progression.coachNote.progressing.loadFirst": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Guter Fortschritt. Erhöhe in der nächsten Einheit leicht und halte die Wiederholungsqualität."
          }
        }
      }
    },
    "progression.coachNote.progressing.repFirst": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stabiler Aufbau. Ergänze ein bis zwei Wiederholungen mit gleichem Gewicht, bevor du die Last erhöhst."
          }
        }
      }
    },
    "progression.coachNote.regressing": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Leistung fällt ab. Reduziere die Last um 10-15 % und baue mit sauberer Technik neu auf. Das ist normal - es zeigt, dass du hart gepusht hast."
          }
        }
      }
    },
    "progression.coachNote.stalling.default": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Fortschritt wird leicht langsamer. Fokus auf saubere Wiederholungen und kontrolliertes Tempo - die Progression kommt."
          }
        }
      }
