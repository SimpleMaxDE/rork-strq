          "stringUnit": {
            "state": "translated",
            "value": "Plan durchziehen"
          }
        }
      }
    },
    "You're well-recovered. Follow today's prescription exactly - this is the kind of day progress is built on. Nothing fancy.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist gut erholt. Folge heute genau der Vorgabe - auf solchen Tagen entsteht Fortschritt. Nichts extra."
          }
        }
      }
    },
    "Hit target reps at target RPE": {
